rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Conversations & messages du chat IA mascotte
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Fan tokens — lecture seule côté client (vérification accès)
    match /fan_tokens/{tokenId} {
      allow read: if request.auth != null;
      allow write: if false; // Écriture uniquement via backend
    }

    // Commandes — jamais accessibles côté client
    match /orders/{orderId} {
      allow read, write: if false;
    }

    // Tout le reste — refus par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
