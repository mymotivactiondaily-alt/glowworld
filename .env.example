# ===== STRIPE =====
# Mode TEST → Dashboard Stripe → Developers → API Keys
# Mode LIVE → Activer le mode Live puis copier les clés
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXX
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXX

# ===== ANALYTICS =====
# Google Analytics 4 → analytics.google.com → Admin → Data Streams
# Copie l'ID de mesure (format: G-XXXXXXXXXX)
# ➜ À remplacer dans index.html (2 endroits)

# TikTok Pixel → ads.tiktok.com → Assets → Events → Setup Web Events
# Copie l'ID du pixel (format: CXXXXXXXXXXXXXXX)
# ➜ À remplacer dans index.html (1 endroit)

# Meta Pixel → business.facebook.com → Events Manager → Connect Data
# Copie l'ID du pixel (format: 16 chiffres)
# ➜ À remplacer dans index.html (2 endroits)

# ===== GEMINI (optionnel) =====
GEMINI_API_KEY=

# ===== RAILWAY =====
# PORT est automatiquement assigné par Railway, ne pas modifier
# NODE_ENV=production est automatiquement défini par Railway
